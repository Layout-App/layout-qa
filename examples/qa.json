{
  "version": 1,
  "app": {
    "root": ".",
    "install": "npm ci",
    "start": "npm run dev -- --host 127.0.0.1 --port $PORT",
    "env": {
      "LAYOUT_QA": "1",
      "VITE_LAYOUT_QA": "1",
      "VITE_API_BASE_URL": "$LAYOUT_MOCK_API_URL"
    }
  },
  "mockApi": {
    "root": ".layout/mocks",
    "defaultScenario": "happy_path"
  },
  "viewports": ["desktop"],
  "flows": [
    {
      "id": "smoke",
      "label": "Smoke",
      "scenarios": ["happy_path"],
      "steps": [
        {"visit": "/"},
        {
          "screenshot": "Initial screen",
          "expect": {
            "noConsoleErrors": true
          }
        },
        {
          "id": "no_horizontal_overflow",
          "type": "assert_no_horizontal_overflow"
        },
        {
          "id": "main_in_viewport",
          "type": "assert_in_viewport",
          "selector": "main"
        }
      ]
    }
  ]
}
