{
  "version": 1,
  "apps": {
    "app": {
      "root": ".",
      "install": "npm ci",
      "start": "npm run dev -- --host 127.0.0.1 --port $PORT",
      "healthUrl": "http://127.0.0.1:$PORT/",
      "services": {
        "api": {
          "type": "mock",
          "root": ".layout/api",
          "scenario": "happy_path"
        }
      },
      "env": {
        "VITE_API_BASE_URL": "$services.api.url"
      },
      "flows": [
        {
          "id": "smoke",
          "label": "Smoke",
          "scenarios": ["happy_path"],
          "steps": [
            {"visit": "/"},
            {
              "screenshot": "Initial screen",
              "expect": {
                "noConsoleErrors": true
              }
            },
            {
              "id": "no_horizontal_overflow",
              "type": "assert_no_horizontal_overflow"
            },
            {
              "id": "main_in_viewport",
              "type": "assert_in_viewport",
              "selector": "main"
            }
          ]
        }
      ]
    }
  },
  "viewports": ["desktop"]
}
